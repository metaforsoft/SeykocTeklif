{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Matching API",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--inspect=9229", "-r", "ts-node/register"],
      "args": ["apps/matching-api/src/index.ts"],
      "env": {
        "MATCH_PG_HOST": "localhost",
        "MATCH_PG_PORT": "5433",
        "API_PORT": "8081"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Sync Service",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--inspect=9230", "-r", "ts-node/register"],
      "args": ["apps/sync-service/src/index.ts"],
      "env": {
        "MATCH_PG_HOST": "localhost",
        "MATCH_PG_PORT": "5433"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Order Dispatcher",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--inspect=9231", "-r", "ts-node/register"],
      "args": ["apps/order-dispatcher/src/index.ts"],
      "env": {
        "MATCH_PG_HOST": "localhost",
        "MATCH_PG_PORT": "5433"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Debug All Services",
      "configurations": ["Debug Matching API", "Debug Sync Service", "Debug Order Dispatcher"]
    }
  ]
}
